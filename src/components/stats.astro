---
import { Card } from "./ui/card";

const CONTENT = [
	{ number: "10+", text: "Clients Served" },
	{ number: "50+", text: "Projects Delivered" },
	{ number: "2x", text: "Average Conversion Improvement" },
];
---

<section class="w-full py-12 md:py-16">
	<div class="text-center">
		<h1 class="heading">Stats</h1>
		<h2 class="sub-heading">Numbers that speak</h2>
	</div>
	<div class="mx-auto flex max-w-5xl flex-col items-center gap-8">
		<div class="grid w-full gap-6 sm:grid-cols-3">
			{
				CONTENT.map((content) => {
					return (
						<Card className="flex h-40 w-full flex-col items-center justify-center gap-1 rounded-2xl  bg-white/5 text-center shadow-sm backdrop-blur-sm sm:h-44">
							<h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{content.number}</h2>
							<p class="text-sm text-muted-foreground md:text-base">{content.text}</p>
						</Card>
					);
				})
			}
		</div>
	</div>
</section>

<hr class="hr" />
