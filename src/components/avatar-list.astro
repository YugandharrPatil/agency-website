---
import { Image } from "astro:assets";

import avatar1 from "../assets/images/avatars/avatar1.png";
import avatar2 from "../assets/images/avatars/avatar2.png";
import avatar3 from "../assets/images/avatars/avatar3.png";

const AVATARS = [
	{ src: avatar1, alt: "alt1", fallback: "fb1" },
	{ src: avatar2, alt: "alt2", fallback: "fb2" },
	{ src: avatar3, alt: "alt3", fallback: "fb3" },
];
---

<div class="flex -space-x-2">
	{
		AVATARS.map((avatar) => (
			<div class="relative flex size-8 shrink-0 overflow-hidden rounded-full ring-2 ring-background bg-muted text-muted-foreground">
				<Image src={avatar.src} alt={avatar.alt} class="aspect-square size-full object-cover" />
			</div>
		))
	}
</div>
