---
import { Button } from "./ui/button";
import { Card } from "./ui/card";
import { supabase } from "../lib/supabase";
import axios from "axios";

import { GITHUB_AUTH_TOKEN } from "astro:env/server";

// TYPES
import type { GithubRepoType } from "../utils/types";
import type { Database } from "../../database.types";
import { ExternalLink } from "lucide-react";

const pathname = Astro.url.pathname;

type Project = Database["public"]["Tables"]["projects"]["Row"];

const { data: repos, error } = (await supabase.from("projects").select("*")) as {
	data: Project[] | null;
	error: Error | null;
};

// console.log(repos);

if (error) {
	console.error(error.message);
}

const token = GITHUB_AUTH_TOKEN;

const headers: Record<string, string> = {
	"X-GitHub-Api-Version": "2022-11-28",
	Accept: "application/vnd.github+json",
};
// Avoid sending `Bearer undefined` (GitHub will return 401)
if (token) headers.Authorization = `Bearer ${token}`;

const { data: fetchedRepos } = await axios.get("https://api.github.com/users/YugandharrPatil/repos", {
	params: { per_page: 100 },
	headers,
});

// console.log(fetchedRepos);

// let filteredRepos = repos?.map((r) => fetchedRepos.find((repo: GithubRepoType) => repo.name === r.repo)).filter((repo): repo is GithubRepoType => Boolean(repo));

// filters repos and adds demo video
let filteredRepos = repos
	?.map((r) => {
		const repo = fetchedRepos.find((repo: GithubRepoType) => repo.name === r.repo);
		return repo ? { ...repo, demoVideo: r["demo_video"] } : undefined;
	})
	.filter((repo): repo is GithubRepoType & { demoVideo?: string } => Boolean(repo));

if (pathname == "/") {
	filteredRepos = filteredRepos?.slice(0, 3);
}
---

<section class="container mx-auto space-y-8 py-12">
	<div class="text-center">
		<h1 class="heading">Portfolio</h1>
		<h2 class="sub-heading">Portfolio subheading</h2>
	</div>
	<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
		{
			filteredRepos?.map((repo: GithubRepoType) => {
				return (
					<Card className="flex h-full flex-col justify-between border-muted bg-card/60 p-6">
						<div class="space-y-2">
							<h3 class="text-lg font-semibold">{repo.name}</h3>
							<p class="text-sm text-muted-foreground">{repo.description}</p>
						</div>
						<div class="mt-4 flex gap-4">
							<a href={`${repo.homepage}`} target="_blank" rel="noreferrer">
								<Button disabled={repo.homepage === null} size="sm" className="w-full">
									Visit <ExternalLink className="h-4 w-4" />
								</Button>
							</a>
							<a href={repo.demoVideo || null} target="_blank" rel="noreferrer">
								<Button size="sm" disabled={repo.demoVideo === null} variant="secondary" className="w-full">
									{repo.demoVideo === null ? "Coming soon" : "Watch Demo Video"} <ExternalLink className="h-4 w-4" />
								</Button>
							</a>
						</div>
					</Card>
				);
			})
		}
	</div>
	{
		pathname === "/" ? (
			<div class="flex justify-center">
				<a href="/portfolio">
					<Button variant="outline">See more work</Button>
				</a>
			</div>
		) : null
	}
</section>

<hr class="hr" />
