---
import CTA from "./cta.astro";
// import Ratings from "./ratings.astro";
import { Ratings } from "./react/ratings";
---

<section class="container mx-auto flex flex-col items-center justify-center gap-6 py-16 text-center">
	<div class="max-w-3xl space-y-4">
		<h1 class="text-3xl font-semibold tracking-tight sm:text-4xl md:text-5xl">
			Websites That Turn Visitors Into Revenue
		</h1>
		<h2 class="text-base text-muted-foreground sm:text-lg md:text-xl">
			We design and build high-performing websites that don’t just look good — they generate leads, drive sales,
			and grow your business.
		</h2>
	</div>
	<CTA />
	<!-- <Ratings /> -->
	<Ratings client:load />
</section>
