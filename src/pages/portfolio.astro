---
import Layout from "@/layouts/layout.astro";
import PortfolioComponent from "@/components/portfolio.astro";
---

<Layout title="Portfolio">
	<section class="container mx-auto space-y-8 py-16">
		<div class="mx-auto max-w-2xl space-y-2 text-center">
			<h1 class="heading">Selected work</h1>
			<p class="sub-heading">A few recent projects that show how we think about UX, performance, and content.</p>
