---
import Layout from "@/layouts/layout.astro";
import { Card } from "../components/ui/card";
import { Icon } from "astro-icon/components";

type AboutCardType = {
	id: number;
	icon: string;
	heading: string;
	description: string;
};

const ABOUT_CARDS: AboutCardType[] = [
	{ id: 1, icon: "lucide:code", heading: "What We Do", description: "We build modern websites and web applications tailored to your business needs — fast, responsive, and built to scale." },
	{ id: 2, icon: "lucide:workflow", heading: "How We Work", description: "We follow a collaborative, transparent process — from idea to launch — ensuring you’re involved every step of the way." },
	{ id: 3, icon: "lucide:zap", heading: "Our Approach", description: "We focus on performance, user experience, and clean code to deliver products that not only look great but also deliver results." },
];
---

<Layout title="About">
	<section class="container mx-auto space-y-10 py-16">
		<div class="mx-auto max-w-2xl text-center space-y-2">
			<h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">About Us</h1>
			<p class="text-sm text-muted-foreground sm:text-base">A small team focused on clean, fast websites that are easy to use and simple to maintain.</p>
		</div>
		<div class="mx-auto grid max-w-4xl gap-4 sm:grid-cols-3">
			{
				ABOUT_CARDS.map((card) => {
					return (
						<Card className="space-y-0 border-muted bg-card/60 p-5 text-center">
							<Icon name={card.icon} class="mx-auto text-4xl" />
							<h1 class="text-md font-semibold">{card.heading}</h1>
							<p class="text-sm text-muted-foreground">{card.description}</p>
						</Card>
					);
				})
			}
		</div>
	</section>
	<hr class="hr" />
</Layout>;
